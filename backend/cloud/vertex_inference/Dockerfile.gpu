FROM nvidia/cuda:12.1.0-cudnn8-runtime-ubuntu22.04

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PORT=8080 \
    DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y python3 python3-pip && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY requirements.txt /app/requirements.txt

RUN python3 -m pip install "torch>=2.3" --index-url https://download.pytorch.org/whl/cu121
RUN python3 -m pip install huggingface_hub
RUN python3 -m pip install -r /app/requirements.txt

ARG HF_TOKEN
RUN python3 -c "\
from huggingface_hub import snapshot_download; \
import os; \
snapshot_download(repo_id='unsloth/Qwen3-4B-bnb-4bit', token=os.environ.get('HF_TOKEN'), local_dir='/app/base_model', ignore_patterns=['*.md','*.txt']); \
print('Done')"

COPY server.py /app/server.py

ENV FITSENSE_BASE_MODEL_PATH=/app/base_model

EXPOSE 8080
CMD ["python3", "-m", "uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8080"]
