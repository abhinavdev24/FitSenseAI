# =============================================================================
# FitSenseAI Backend - Environment Variables Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
# The backend loads .env by default; .env.local takes precedence.
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Set DATABASE_ENGINE explicitly. Supported values: mysql, sqlite.
#
# MySQL example for Google Cloud SQL public IP:
# DATABASE_ENGINE=mysql
# DATABASE_USER=fitsensebackend
# DATABASE_PASSWORD=your_password_here
# DATABASE_NAME=fitsense
# DATABASE_HOST=35.224.89.210
# DATABASE_PORT=3306
#
# SQLite example for local development:
# DATABASE_ENGINE=sqlite
# DATABASE_PATH=/absolute/path/to/FitSenseAI/backend/data/fitsense.db

# Default local example:
DATABASE_ENGINE=mysql
DATABASE_USER=fitsensebackend
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=fitsense
DATABASE_HOST=35.224.89.210
DATABASE_PORT=3306

# -----------------------------------------------------------------------------
# OpenAI-Compatible API Configuration
# -----------------------------------------------------------------------------
# Set these to use any OpenAI-compatible API provider (OpenRouter, Groq, etc.)

# API Key for your chosen provider
OPENAI_API_KEY=your_api_key_here

# Full URL to the chat completions endpoint
# Examples:
#   OpenRouter:  https://openrouter.ai/api/v1/chat/completions
#   Groq:        https://api.groq.com/openai/v1/chat/completions
#   Together AI: https://api.together.ai/v1/chat/completions
#   Ollama:     http://localhost:11434/v1/chat/completions
#   LM Studio:  http://localhost:1234/v1/chat/completions
OPENAI_API_URL=https://openrouter.ai/api/v1/chat/completions

# Model identifier (check your provider's available models)
# Examples:
#   OpenRouter:  qwen/qwen3-8b:free, anthropic/claude-3-haiku, meta-llama/llama-3-8b-instruct
#   Groq:        llama-3.1-8b-instant, mixtral-8x7b-32768
#   Together AI: meta-llama/Llama-3-8b-chat-hf
#   Ollama:     llama3, mistral, codellama
OPENAI_MODEL=qwen/qwen3-8b:free

# Optional global cap for generated output tokens (applies to plan + coach generation)
# If unset, backend uses endpoint-specific defaults.
MAX_OUTPUT_TOKENS=2500

# -----------------------------------------------------------------------------
# Cloud Run Inference (Optional - falls back to local model if not set)
# -----------------------------------------------------------------------------
# URL for Cloud Run inference service (if deployed)
# FITSENSE_CLOUDRUN_URL=https://your-service.run.app

# -----------------------------------------------------------------------------
# Student Model Configuration (Optional - falls back to rules if not set)
# -----------------------------------------------------------------------------
# Override the base model name
# FITSENSE_STUDENT_BASE_MODEL=unsloth/Qwen3-4B-bnb-4bit

# Explicit path to a local adapter directory
# FITSENSE_STUDENT_ADAPTER_PATH=/path/to/adapter

# Explicit path to a registry record JSON
# FITSENSE_STUDENT_REGISTRY_RECORD=/path/to/registry_record.json

# Path to a local artifact (directory, .zip, .tar, .tar.gz)
# FITSENSE_STUDENT_ARTIFACT=/path/to/artifact.zip

# -----------------------------------------------------------------------------
# Debugging
# -----------------------------------------------------------------------------
# Set to 0, false, no, or off to disable verbose debug logging
# FITSENSE_DEBUG_VERTEX=1
