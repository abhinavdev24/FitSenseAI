# Backend -> Cloud Run inference
FITSENSE_CLOUDRUN_URL=https://YOUR-CLOUD-RUN-SERVICE-URL

# Optional local fallback if cloud inference is unavailable
# FITSENSE_STUDENT_ADAPTER_PATH=/absolute/path/to/qwen3-4b-v2
# FITSENSE_STUDENT_BASE_MODEL=Qwen/Qwen3-4B

# Optional debug logging
FITSENSE_DEBUG_VERTEX=1
